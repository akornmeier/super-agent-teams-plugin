{
  "name": "tk-agent-team",
  "owner": {
    "name": "Tony Kornmeier",
    "url": "https://github.com/tk"
  },
  "metadata": {
    "description": "Plugin marketplace for Claude Code agent team extensions",
    "version": "0.2.0"
  },
  "plugins": [
    {
      "name": "tk-agent-team",
      "description": "Build durable Agent Teams with per-agent YAML memory. Each teammate reads context at task start and appends learnings at task end — so every task makes the team smarter.",
      "author": {
        "name": "Tony Kornmeier"
      },
      "tags": [
        "agent-teams",
        "memory",
        "mcp",
        "curation",
        "knowledge-management"
      ],
      "display": {
        "color": "#6366F1",
        "emoji": "🧠",
        "agents": [
          {
            "name": "reviewer",
            "personas": ["architecture", "correctness", "security"],
            "color": "#6366F1",
            "emoji": "🏗️"
          },
          {
            "name": "developer",
            "personas": ["frontend", "backend"],
            "color": "#3B82F6",
            "emoji": "⚙️"
          },
          {
            "name": "curator",
            "color": "#F59E0B",
            "emoji": "📚"
          },
          {
            "name": "orchestrator",
            "color": "#EC4899",
            "emoji": "🧭"
          },
          {
            "name": "planner",
            "personas": ["product", "technical"],
            "color": "#8B5CF6",
            "emoji": "📋"
          },
          {
            "name": "researcher",
            "color": "#14B8A6",
            "emoji": "🔬"
          },
          {
            "name": "tester",
            "personas": ["unit", "integration"],
            "color": "#10B981",
            "emoji": "🧪"
          },
          {
            "name": "debugger",
            "color": "#EF4444",
            "emoji": "🐛"
          },
          {
            "name": "docs-writer",
            "color": "#F97316",
            "emoji": "📝"
          }
        ]
      },
      "source": "./plugins/tk-agent-team"
    }
  ]
}
